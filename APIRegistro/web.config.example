<?xml version="1.0" encoding="utf-8"?>
<!--
  ?? IMPORTANTE: Este es un archivo de EJEMPLO
  
  Este archivo muestra cµmo configurar web.config para IIS.
  NO subir este archivo al repositorio con contraseþas reales.
  
  Pasos para usar este archivo:
  1. Copia este archivo a la carpeta publicada en IIS
  2. Renµmbralo a "web.config" (quita el .example)
  3. Reemplaza todos los valores de EJEMPLO con valores reales
  4. Asegºrate de que estÕ en el .gitignore
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      
      <aspNetCore processPath="dotnet" 
                  arguments=".\APIRegistro.dll" 
                  stdoutLogEnabled="true" 
                  stdoutLogFile=".\logs\stdout" 
                  hostingModel="inprocess">
        
        <environmentVariables>
          
          <!-- CADENA DE CONEXIÆN A SQL SERVER -->
          <!-- Reemplaza TU_SERVIDOR_SQL, TU_CONTRASEîA con valores reales -->
          <environmentVariable name="ConnectionStrings__DefaultConnection" 
                               value="Server=TU_SERVIDOR_SQL;Database=EventosESCAT;User Id=EventosESCATUser;Password=TU_CONTRASEîA;TrustServerCertificate=True;Encrypt=True;" />
          
          <!-- JWT SECRET KEY -->
          <!-- Genera una clave aleatoria de al menos 64 caracteres -->
          <!-- PowerShell: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 64 | ForEach-Object {[char]$_}) -->
          <environmentVariable name="JWT__SecretKey" 
                               value="GENERA_UNA_CLAVE_ALEATORIA_DE_AL_MENOS_64_CARACTERES_AQUI" />
          
          <!-- ISSUER Y AUDIENCE DE JWT (opcional, usa valores por defecto si no se especifican) -->
          <environmentVariable name="JWT__Issuer" 
                               value="APIRegistro" />
          <environmentVariable name="JWT__Audience" 
                               value="APIRegistroUsers" />
          <environmentVariable name="JWT__ExpirationHours" 
                               value="24" />
          
          <!-- ENTORNO DE EJECUCIÆN -->
          <!-- Production: Sin Swagger, sin mensajes de error detallados -->
          <!-- Development: Con Swagger, mensajes de error detallados -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" 
                               value="Production" />
          
          <!-- CORS - OrÚgenes permitidos (opcional) -->
          <!-- Separar mºltiples orÚgenes con comas -->
          <environmentVariable name="AllowedOrigins" 
                               value="https://tu-dominio.com,https://www.tu-dominio.com" />
          
          <!-- ALLOWED HOSTS (opcional) -->
          <environmentVariable name="AllowedHosts" 
                               value="*" />
          
        </environmentVariables>
      </aspNetCore>
      
      <!-- HTTPS Redirect (opcional, descomenta si no usas URL Rewrite) -->
      <!--
      <rewrite>
        <rules>
          <rule name="HTTPS Redirect" stopProcessing="true">
            <match url="(.*)" />
            <conditions>
              <add input="{HTTPS}" pattern="^OFF$" />
            </conditions>
            <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
          </rule>
        </rules>
      </rewrite>
      -->
      
    </system.webServer>
  </location>
</configuration>

<!--
  NOTAS DE SEGURIDAD:
  
  1. ?? NUNCA subir este archivo al repositorio con valores reales
  2. ?? Proteger este archivo con permisos adecuados en el servidor
  3. ? Usar contraseþas fuertes (mÚnimo 12 caracteres, mayºsculas, minºsculas, nºmeros, sÚmbolos)
  4. ? Cambiar contraseþas regularmente (cada 90 dÚas recomendado)
  5. ? Usar JWT SecretKey ºnica para cada entorno
  6. ? Habilitar stdoutLogEnabled solo temporalmente para debugging
  7. ? Revisar logs regularmente y eliminar informaciµn sensible
  
  VALORES DE EJEMPLO PARA REEMPLAZAR:
  
  - TU_SERVIDOR_SQL: Ejemplos
    * localhost\SQLEXPRESS
    * 192.168.1.100
    * sql.tudominio.com
    * servidor-sql.local,1433
  
  - TU_CONTRASEîA: 
    * MÚnimo 12 caracteres
    * Incluir mayºsculas, minºsculas, nºmeros y sÚmbolos
    * Ejemplo (NO USAR): Ev3nt0s#ESCAT@2024$Secure!
  
  - GENERA_UNA_CLAVE_ALEATORIA...:
    * Usar PowerShell para generar:
      -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 64 | ForEach-Object {[char]$_})
    * Debe ser ºnica y diferente para cada entorno
  
  ENTORNOS:
  
  - Production: Para producciµn (sin Swagger, sin detalles de errores)
  - Staging: Para pruebas pre-producciµn
  - Development: Para desarrollo (con Swagger, con detalles de errores)
  
  CONSULTA LA DOCUMENTACIÆN COMPLETA EN:
  - DESPLIEGUE_IIS.md: GuÚa paso a paso de despliegue
  - SEGURIDAD.md: Recomendaciones de seguridad
  - README.md: Informaciµn general de la API
-->
